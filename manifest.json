{
  "schema": 2,
  "permissions": ["tools.invoke", "storage.read", "storage.write"],
  "required_executas": [
    {
      "tool_id": "tool-dev-mini-notes"
    }
  ],
  "tags": ["mini-notes", "notes"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "最小笔记",
        "default": true,
        "default_size": { "w": 520, "h": 560 },
        "min_size": { "w": 320, "h": 360 }
      }
    ],
    "host_api": {
      "tools": ["tool-dev-mini-notes"],
      "storage": ["get", "set"],
      "window": ["set_title", "ready"]
    },
    "csp_overrides": {},
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "seed_storage": {},
    "user_id": 1
  }
}
